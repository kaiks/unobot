#!/bin/sh
set -eu

root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
image=${UNO_IMAGE:?set UNO_IMAGE to the built image tag or immutable ID}
checkpoint=${UNO_CHECKPOINT:?set UNO_CHECKPOINT to jedna_multiplayer_v3.zip}
expected=${UNO_NEURAL_CHECKPOINT_SHA256:-716e687a637632e286e0050b1e013ded46af95033bf5a45901163cc0c141aa15}
unobot_ref=$(git -C "$root" rev-parse "${UNOBOT_REF:-HEAD}^{commit}")
: "${JEDNA_REF:?set JEDNA_REF to the reviewed multiplayer-v3 Jedna commit}"
jedna_ref=$(git -C "${JEDNA_ROOT:-$root/../jedna}" rev-parse "$JEDNA_REF^{commit}")

case "$checkpoint" in /*) ;; *) echo 'UNO_CHECKPOINT must be an absolute path' >&2; exit 2 ;; esac

actual_id=$(docker image inspect "$image" --format '{{.Id}}')
test -z "${UNO_EXPECTED_IMAGE_ID:-}" || test "$actual_id" = "$UNO_EXPECTED_IMAGE_ID"
test "$(docker image inspect "$image" --format '{{index .Config.Labels "org.opencontainers.image.revision"}}')" = "$unobot_ref"
test "$(docker image inspect "$image" --format '{{index .Config.Labels "org.opencontainers.image.jedna.revision"}}')" = "$jedna_ref"

test "$(sha256sum "$checkpoint" | cut -d ' ' -f 1)" = "$expected"

docker run --rm --platform linux/amd64 --read-only \
  --tmpfs /tmp:rw,noexec,nosuid,nodev,size=64m "$image" \
  /bin/sh -c "ruby -e \"abort unless RUBY_VERSION == '4.0.6'\" && python3 -c \"import sys; assert sys.version_info[:3] == (3,11,2)\" && /opt/venv/bin/python -c \"import gymnasium,numpy,sb3_contrib,stable_baselines3,torch; assert torch.__version__ == '2.8.0+cpu'; assert stable_baselines3.__version__ == sb3_contrib.__version__ == '2.7.0'; assert gymnasium.__version__ == '1.2.0'; assert numpy.__version__ == '2.3.5'\" && /opt/venv/bin/python -c \"from importlib.metadata import version; expected = {'filelock': '3.31.1', 'fonttools': '4.63.0', 'Jinja2': '3.1.6', 'Pillow': '12.3.0', 'pip': '26.1.2', 'setuptools': '83.0.0'}; assert {name: version(name) for name in expected} == expected\""

docker run --rm --platform linux/amd64 "$image" /bin/sh -c \
  'test "$(id -u)" = 10001 && test ! -e /models/jedna_multiplayer_v3.zip && test ! -d /unobot/.git && test ! -d /unobot/test && test ! -e /opt/jedna-tournaments/examples/rl_agent/train_sb3.py'

requests=$(docker run --rm --platform linux/amd64 --read-only \
  --tmpfs /tmp:rw,noexec,nosuid,nodev,size=64m "$image" ruby -rjson -e '
  (2..10).each do |players|
    others = (2..players).map { |index| { id: "player#{index}", card_count: index } }
    puts JSON.generate(type: "request_action", state: {
      your_id: "bot", hand: ["r5"], top_card: "b7", game_state: "normal",
      stacked_cards: 0, already_picked: false, picked_card: nil,
      other_players: others, available_actions: ["draw"], playable_cards: []
    })
  end
')
responses=$(printf '%s\n' "$requests" | \
  docker run --rm -i --platform linux/amd64 --read-only --memory=1g --pids-limit=128 \
    --mount "type=bind,source=$checkpoint,target=/models/jedna_multiplayer_v3.zip,readonly" \
    --tmpfs /tmp:rw,noexec,nosuid,nodev,size=64m \
    -e UNO_STRATEGY=Neural "$image" \
    /bin/sh -c 'cd /opt/jedna-tournaments/examples && exec /opt/venv/bin/python -m rl_agent.sb3_opponent --model /models/jedna_multiplayer_v3.zip')

printf '%s\n' "$responses" | \
  docker run --rm -i --platform linux/amd64 --read-only \
    --tmpfs /tmp:rw,noexec,nosuid,nodev,size=64m "$image" ruby -rjson -e \
    'lines = STDIN.readlines(chomp: true); abort unless lines.length == 9; abort unless lines.map { |line| JSON.parse(line) }.all? { |action| action == { "action" => "draw" } }'
printf '%s\n' "$responses"
