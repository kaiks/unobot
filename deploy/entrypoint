#!/bin/sh
set -eu

umask 077

live_strategy=$(printf '%s' "${UNO_STRATEGY:-}" | tr '[:upper:]' '[:lower:]')
shadow_strategy=$(printf '%s' "${UNO_SHADOW_STRATEGY:-}" | tr '[:upper:]' '[:lower:]')
if [ "$live_strategy" = neural ] || [ "$shadow_strategy" = neural ]; then
  checkpoint=${UNO_NEURAL_CHECKPOINT:-/models/jedna_multiplayer_v3.zip}
  expected=${UNO_NEURAL_CHECKPOINT_SHA256:-0b1d3a62605a2a4834cd758f0038d33140bd91087a28d99b3c84a959e601340f}
  if [ ! -r "$checkpoint" ]; then
    echo 'neural checkpoint is not readable' >&2
    exit 78
  fi
  actual=$(sha256sum "$checkpoint" | cut -d ' ' -f 1)
  if [ "$actual" != "$expected" ]; then
    echo 'neural checkpoint checksum does not match deployment configuration' >&2
    exit 78
  fi
fi

mkdir -p logs

child=''
terminate() {
  if [ -n "$child" ]; then
    kill -TERM "$child" 2>/dev/null || true
    wait "$child" 2>/dev/null || true
  fi
  exit 0
}
trap terminate INT TERM

# POSIX shells may attach /dev/null to an asynchronous command's standard input.
# Preserve the caller's descriptor explicitly for JSON-lines process agents.
exec 3<&0
"$@" <&3 3<&- &
child=$!
exec 3<&-
set +e
wait "$child"
status=$?
set -e
trap - INT TERM
exit "$status"
