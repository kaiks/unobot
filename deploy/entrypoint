#!/bin/sh
set -eu

umask 077

live_strategy=$(printf '%s' "${UNO_STRATEGY:-}" | tr '[:upper:]' '[:lower:]')
shadow_strategy=$(printf '%s' "${UNO_SHADOW_STRATEGY:-}" | tr '[:upper:]' '[:lower:]')
if [ "$live_strategy" = neural ] || [ "$shadow_strategy" = neural ]; then
  checkpoint=${UNO_NEURAL_CHECKPOINT:-/models/checkpoint_17500000_steps.zip}
  expected=${UNO_NEURAL_CHECKPOINT_SHA256:-3399184a589bce389377ca446f1dcb278cdf9123f5a3971031fbee24d5277b4f}
  if [ ! -r "$checkpoint" ]; then
    echo 'neural checkpoint is not readable' >&2
    exit 78
  fi
  actual=$(sha256sum "$checkpoint" | cut -d ' ' -f 1)
  if [ "$actual" != "$expected" ]; then
    echo 'neural checkpoint checksum does not match deployment configuration' >&2
    exit 78
  fi
fi

mkdir -p logs

child=''
terminate() {
  if [ -n "$child" ]; then
    kill -TERM "$child" 2>/dev/null || true
    wait "$child" 2>/dev/null || true
  fi
  exit 0
}
trap terminate INT TERM

"$@" &
child=$!
set +e
wait "$child"
status=$?
set -e
trap - INT TERM
exit "$status"
